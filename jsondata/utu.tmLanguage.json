{
  "name": "UTU",
  "scopeName": "source.utu",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#testBench"
    },
    {
      "include": "#jsgen"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#parameters"
    },
    {
      "include": "#types"
    },
    {
      "include": "#members"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#invocations"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.utu",
          "match": "//.*$"
        }
      ]
    },
    "testBench": {
      "patterns": [
        {
          "name": "meta.test-or-bench.utu",
          "match": "\\b(test|bench)\\s+(\"(?:\\\\.|[^\"\\\\])*\")",
          "captures": {
            "1": {
              "name": "keyword.control.utu"
            },
            "2": {
              "name": "entity.name.section.utu"
            }
          }
        }
      ]
    },
    "jsgen": {
      "patterns": [
        {
          "name": "meta.declaration.jsgen.utu",
          "begin": "\\b(escape)\\b\\s+\\|",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.utu"
            }
          },
          "end": "\\|(?=\\s+[a-z_][a-zA-Z0-9_]*\\s*\\()",
          "patterns": [
            {
              "begin": "(?=[^|])",
              "end": "(?=\\|)",
              "contentName": "meta.embedded.inline.javascript",
              "patterns": [
                {
                  "include": "source.js"
                }
              ]
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.other.multiline.utu",
          "match": "\\\\\\\\[^\\n]*$"
        },
        {
          "name": "string.quoted.double.utu",
          "match": "\"(?:\\\\.|[^\"\\\\])*\""
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.utu",
          "match": "\\b\\d+\\.\\d+(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.utu",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.utu",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.integer.utu",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.function.utu",
          "match": "\\b(?:(export)\\s+)?(fun)\\s+([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "keyword.control.utu"
            },
            "2": {
              "name": "keyword.control.utu"
            },
            "3": {
              "name": "entity.name.function.utu"
            }
          }
        },
        {
          "name": "meta.declaration.import-function.utu",
          "match": "\\b(shimport)\\s+(\"[^\"]+\")\\s+([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "keyword.control.utu"
            },
            "2": {
              "name": "string.quoted.double.utu"
            },
            "3": {
              "name": "entity.name.function.utu"
            }
          }
        },
        {
          "name": "meta.declaration.import-value.utu",
          "match": "\\b(shimport)\\s+(\"[^\"]+\")\\s+([a-z_][a-zA-Z0-9_]*)\\s*(?=\\s*:)",
          "captures": {
            "1": {
              "name": "keyword.control.utu"
            },
            "2": {
              "name": "string.quoted.double.utu"
            },
            "3": {
              "name": "variable.other.definition.utu"
            }
          }
        },
        {
          "name": "meta.declaration.type.utu",
          "match": "\\b(struct|type)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.utu"
            },
            "2": {
              "name": "entity.name.type.utu"
            }
          }
        },
        {
          "name": "meta.variant.utu",
          "match": "(\\|)\\s*([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.union.utu"
            },
            "2": {
              "name": "entity.name.type.variant.utu"
            }
          }
        },
        {
          "name": "meta.declaration.binding.utu",
          "match": "\\b(let)\\s+([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.utu"
            },
            "2": {
              "name": "variable.other.definition.utu"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.utu",
          "match": "\\b(?:if|else|match|alt|for|while|break|emit|let|export|shimport|escape|fun|get|struct|type|proto|test|bench|setup|measure|assert|mut|and(?!\\=)|or(?!\\=)|not|fatal|void|construct|mod|rec|promote|tag)\\b"
        },
        {
          "name": "constant.language.boolean.utu",
          "match": "\\b(?:true|false|null)\\b"
        }
      ]
    },
    "parameters": {
      "patterns": [
        {
          "name": "meta.parameter.utu",
          "match": "([,(])\\s*([a-z_][a-zA-Z0-9_]*)\\s*(?=:)",
          "captures": {
            "1": {
              "name": "punctuation.separator.parameters.utu"
            },
            "2": {
              "name": "variable.parameter.utu"
            }
          }
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.utu",
          "match": "\\b(?:i32|u32|i64|u64|f32|f64|v128|bool|void|str|externref|anyref|eqref|i31|array|ref)\\b"
        },
        {
          "name": "support.type.user.utu",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "members": {
      "patterns": [
        {
          "name": "variable.other.member.utu",
          "match": "\\.\\s*([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "variable.other.property.utu"
            }
          }
        },
        {
          "name": "meta.property.utu",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=:)",
          "captures": {
            "1": {
              "name": "variable.other.property.utu"
            }
          }
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.utu",
          "match": "\\b(?:array|i31|ref|extern|any|i32|i64|f32|f64)\\.[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "invocations": {
      "patterns": [
        {
          "name": "support.function.call.utu",
          "match": "\\b(?!if\\b|else\\b|match\\b|alt\\b|for\\b|break\\b|emit\\b|let\\b|export\\b|shimport\\b|escape\\b|fun\\b|get\\b|struct\\b|type\\b|proto\\b|test\\b|bench\\b|setup\\b|measure\\b|assert\\b|mut\\b|and\\b|or\\b|not\\b|fatal\\b|void\\b|construct\\b|mod\\b|rec\\b|promote\\b|tag\\b)([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.utu"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.utu",
          "match": "and=|or=|>>>=|>>=|<<=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|-o|=>|\\.\\.\\.|\\.\\.<|#|\\\\|==|!=|<=|>=|>>>|<<|>>|[-+*/%&^|=<>;]"
        }
      ]
    }
  }
}
