{
  "name": "UTU",
  "scopeName": "source.utu",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.utu",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.other.multiline.utu",
          "match": "\\\\\\\\[^\\n]*$"
        },
        {
          "name": "string.quoted.double.utu",
          "match": "\"(?:\\\\.|[^\"\\\\])*\""
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.utu",
          "match": "\\b\\d+\\.\\d+(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.utu",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.utu",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.integer.utu",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.function.utu",
          "match": "\\b(?:export\\s+)?fn\\s+([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.utu"
            }
          }
        },
        {
          "name": "meta.declaration.type.utu",
          "match": "\\b(?:struct|type)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.type.utu"
            }
          }
        },
        {
          "name": "meta.variant.utu",
          "match": "(\\|)\\s*([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.operator.union.utu"
            },
            "2": {
              "name": "entity.name.type.variant.utu"
            }
          }
        },
        {
          "name": "meta.declaration.binding.utu",
          "match": "\\blet\\s+([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "variable.other.definition.utu"
            }
          }
        },
        {
          "name": "meta.import.utu",
          "match": "\\bimport\\s+extern\\s+\"[^\"]*\"\\s+([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.function.utu"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.utu",
          "match": "\\b(?:if|else|match|for|break|let|import|extern|export|fn|struct|type|mut|and|or|not|unreachable)\\b"
        },
        {
          "name": "constant.language.boolean.utu",
          "match": "\\b(?:true|false|null)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.utu",
          "match": "\\b(?:i32|u32|i64|u64|f32|f64|v128|bool|str|externref|anyref|eqref|i31|array|ref)\\b"
        },
        {
          "name": "support.type.user.utu",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.utu",
          "match": "\\b(?:str|array|i31|ref|extern|any|i32|i64|f32|f64)\\.[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.utu",
          "match": "-o|=>|\\.\\.|#|\\\\|==|!=|<=|>=|>>>|<<|>>|[-+*/%&^|=<>]"
        }
      ]
    }
  }
}
