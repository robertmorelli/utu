{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "UTU: Watch Web Extension",
      "type": "shell",
      "command": "npm run watch:web",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "NO_COLOR": "1",
          "FORCE_COLOR": "0"
        }
      },
      "isBackground": true,
      "group": "build",
      "problemMatcher": [
        {
          "base": "$tsc-watch",
          "background": {
            "activeOnStart": true,
            "beginsPattern": "Watching UTU web extension sources\\.\\.\\.",
            "endsPattern": "\\[watch\\] build finished, watching for changes\\.\\.\\."
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
