{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "UTU: Build Grammar",
      "type": "shell",
      "command": "bun",
      "args": [
        "run",
        "grammar"
      ],
      "options": {
        "cwd": "${workspaceFolder}/..",
        "env": {
          "NO_COLOR": "1",
          "FORCE_COLOR": "0"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "UTU: Distribute Grammar",
      "type": "shell",
      "command": "bun",
      "args": [
        "run",
        "distribute"
      ],
      "options": {
        "cwd": "${workspaceFolder}/..",
        "env": {
          "NO_COLOR": "1",
          "FORCE_COLOR": "0"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "UTU: Prepare Web Extension",
      "dependsOrder": "sequence",
      "dependsOn": [
        "UTU: Build Grammar",
        "UTU: Distribute Grammar"
      ],
      "group": "build"
    },
    {
      "label": "UTU: Watch Web Extension",
      "type": "shell",
      "command": "npm run watch:web",
      "dependsOrder": "sequence",
      "dependsOn": [
        "UTU: Prepare Web Extension"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "NO_COLOR": "1",
          "FORCE_COLOR": "0"
        }
      },
      "isBackground": true,
      "group": "build",
      "problemMatcher": [
        {
          "owner": "utu-web-watch",
          "pattern": {
            "regexp": "$a"
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^Watching UTU web extension sources\\.\\.\\.$",
            "endsPattern": "^UTU_WEB_EXTENSION_READY$"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
