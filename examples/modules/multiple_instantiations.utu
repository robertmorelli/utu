mod bucket[T] {
    struct Box {
        value: T,
    }

    fun Box.new(value: T) Box {
        Box { value: value };
    }

    fun Box.get(self: Box) T {
        self.value;
    }

    fun id(value: T) T {
        value;
    }
}

construct ints = bucket[i32];
construct flags = bucket[bool];

fun read_int(box: ints.Box) i32 {
    box.get();
}

fun read_flag(box: flags.Box) bool {
    box.get();
}

test "multiple instantiations keep separate qualified types" {
    let int_box: ints.Box = ints.Box.new(6);
    let flag_box: flags.Box = flags.Box.new(true);
    assert read_int(int_box) == 6;
    assert read_flag(flag_box);
}

test "inline paths resolve the matching instantiation" {
    let int_box: bucket[i32].Box = ints.Box.new(4);
    let flag_box: bucket[bool].Box = flags.Box.new(false);
    assert int_box.get() == 4;
    assert not flag_box.get();
}

test "free functions resolve through both construct aliases" {
    assert ints.id(8) == 8;
    assert flags.id(true);
}

test "multiple instantiations keep their own associated calls" {
    let int_box: ints.Box = ints.Box.new(12);
    let flag_box: flags.Box = flags.Box.new(true);
    assert int_box.get() == 12;
    assert flag_box.get();
}
