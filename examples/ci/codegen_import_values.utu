import extern "es" lucky: i32
import extern "es" label: str
import extern "es" document: externref

fn score() i32 {
    lucky + 1
}

fn named() bool {
    str.equals(label, "utu")
}

fn doc_present() bool {
    not ref.is_null(document)
}

test "imported numeric globals contribute to arithmetic" {
    assert score() == 42
}

test "imported string globals flow into string builtins" {
    assert named()
}

test "imported externref globals can stay non-null" {
    assert doc_present()
}
