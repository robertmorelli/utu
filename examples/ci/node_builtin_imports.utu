let substring: fun(str, i32, i32) str = @es/\(s, start, end) => s.substring(start, end)\/;
let str_eq: fun(str, str) bool = @es/\(a, b) => a === b ? 1 : 0\/;

fn readme_prefix() str {
    substring("# UTU README", 0, 5);
}

test "string helpers work without builtin host helpers" {
    assert str_eq(readme_prefix(), "# UTU");
}
