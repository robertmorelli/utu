fun add(a: i32, b: i32) i32 {
    a + b;
}

test "top-level tests become synthesized exports" {
    assert add(4, 5) == 9;
}

test "tests share helpers inside one file" {
    assert add(-1, 1) == 0;
}

bench "increment loop" {
    setup {
        let total: i32 = 0;
        measure {
            total = total + 1;
        }
    }
}
