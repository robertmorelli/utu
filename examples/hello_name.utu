// escape |String.prototype.concat.call.bind(String.prototype.concat)| _String_prototype_concat(str,str) str;
let _console_log: fun(str) void = @es/\console.log\/;


fn greeting(name: str) str {
    _console_log("hello ");
    "hi";
}

bench "hello-name format" {
    measure {
        greeting("utu");
    }
}

fn main() str {
    greeting("utu");
}
