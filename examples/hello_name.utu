shimport "es" _console_log(str) void;


fun greeting(name: str) str {
    _console_log("hello ");
    "hi";
}

bench "hello-name format" |i| {
    setup {
        measure {
            greeting("utu");
        }
    }
}

export fun main() str {
    greeting("utu");
}
