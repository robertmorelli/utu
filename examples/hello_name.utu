// escape |String.prototype.concat.call.bind(String.prototype.concat)| _String_prototype_concat(str,str) str;
escape |console.log| _console_log(str) void;


fun greeting(name: str) str {
    _console_log("hello ");
    "hi";
}

bench "hello-name format" {
    setup {
        measure {
            greeting("utu");
        }
    }
}

fun main() str {
    greeting("utu");
}
