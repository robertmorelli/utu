{
  "name": "@utu/cli-artifact",
  "private": true,
  "type": "module",
  "bin": {
    "utu": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --target bun --outfile ./dist/utu.js",
    "smoke:compile": "bun run ./src/cli.ts compile ../examples/call_simple.utu --outdir ./dist/smoke",
    "smoke:run": "bun run ./src/cli.ts run ../examples/call_simple.utu"
  },
  "engines": {
    "bun": ">=1.2.17"
  }
}
