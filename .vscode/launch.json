{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "UTU: Run Web Extension in VS Code",
      "type": "extensionHost",
      "debugWebWorkerHost": true,
      "request": "launch",
      "preLaunchTask": "UTU: Rebuild",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/dist/web-dev-extension",
        "--extensionDevelopmentKind=web"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/web/**/*.js"
      ]
    }
  ]
}
