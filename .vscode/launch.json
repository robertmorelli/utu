{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "UTU: Run Web Extension in VS Code",
      "type": "pwa-extensionHost",
      "debugWebWorkerHost": true,
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode",
        "--extensionDevelopmentKind=web"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode/dist/web/**/*.js"
      ],
      "preLaunchTask": "UTU: Watch Web Extension"
    }
  ]
}
