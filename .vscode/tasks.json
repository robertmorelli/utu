{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "UTU: Rebuild",
      "type": "shell",
      "command": "bun",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "NO_COLOR": "1",
          "FORCE_COLOR": "0"
        }
      },
      "group": "build"
    },
    {
      "label": "UTU: Watch",
      "type": "shell",
      "command": "bun",
      "args": [
        "run",
        "watch"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "NO_COLOR": "1",
          "FORCE_COLOR": "0"
        }
      },
      "isBackground": true,
      "group": "build",
      "problemMatcher": [
        {
          "owner": "utu-watch",
          "pattern": {
            "regexp": "$a"
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^Watching UTU extension sources\\.\\.\\.$",
            "endsPattern": "^UTU_EXTENSION_READY$"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
